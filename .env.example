# Copy to ".env.local" for local development (Next.js loads it automatically).

# --- Database (required) ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority
# Vercel: set MONGODB_URI for Preview too (same cluster with a `preview` DB name is fine) so PR previews work.

# --- Auth.js / NextAuth (required) ---
# Generate: npx auth secret
NEXTAUTH_SECRET=paste-a-long-random-string-at-least-32-chars
# Same value is fine; the app maps NEXTAUTH_SECRET -> AUTH_SECRET if needed.
AUTH_SECRET=

# Must match the URL you open in the browser (include http for local, https for prod).
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# --- Google sign-in (optional but needed for "Sign in with Google") ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web).
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub sign-in (optional) ---
# Callback: {NEXTAUTH_URL}/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Optional: require this header value (x-cleanup-secret) for POST /api/cleanup-database in production.
# CLEANUP_DATABASE_SECRET=

# --- Get started fast (set true while testing; turn OFF for real customers) ---
# If "true", new customer signups + first-time Google/GitHub users are approved immediately.
AUTO_APPROVE_CUSTOMER_SIGNUPS=false
